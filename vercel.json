{
  "installCommand": "cd apps/web && npm install",
  "buildCommand": "cd apps/web && npm run build",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "experimentalServices": {
    "web": {
      "root": "apps/web",
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "api": {
      "root": "services/api",
      "entrypoint": "app.main:app",
      "routePrefix": "/_/api"
    }
  }
}
