# App
APP_ENV=development
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS_RAW=http://localhost:3000,http://127.0.0.1:3000

# Database
DATABASE_URL=postgresql+asyncpg://smartdocs:smartdocs@postgres:5432/smartdocs

# Redis
REDIS_URL=redis://redis:6379/0

# File Storage
UPLOAD_DIR=/uploads
MAX_FILE_SIZE_MB=20

# AI Provider Mode
AI_PROVIDER_MODE=auto

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat

# Qwen / Dashscope
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-plus

# OpenAI-compatible fallback
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini

# Embedding
EMBEDDING_PROVIDER=auto
EMBEDDING_MODEL=text-embedding-v3
QWEN_EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSION=1024
DEMO_EMBEDDING_DIM=1024

# Langfuse
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Rate Limiting
RAG_RATE_LIMIT_PER_USER=30/minute
RAG_RATE_LIMIT_PER_WORKSPACE=100/minute

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
